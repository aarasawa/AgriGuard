{
  "entities": {
    "PesticideApplication": {
      "title": "Pesticide Application",
      "description": "A record of a historical pesticide application from the PUR database.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "applicationDate": { "type": "string", "format": "date-time" },
        "pesticideName": { "type": "string" },
        "cropName": { "type": "string" },
        "amountApplied": { "type": "number" },
        "unit": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "county": { "type": "string" },
        "siteCode": { "type": "string" },
        "applicatorName": { "type": "string" }
      },
      "required": ["applicationDate", "pesticideName", "latitude", "longitude"]
    }
  },
  "firestore": {
    "/pesticide_applications": {
      "schema": "PesticideApplication",
      "description": "Collection of historical pesticide use reports."
    }
  }
}
